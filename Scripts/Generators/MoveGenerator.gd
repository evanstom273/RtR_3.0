    # Helper to convert Enum to a folder name

    var class_to_folder := {
        LegacyMovePool.STANDING_IN_FRONT: "Standing",
        LegacyMovePool.STANDING_BEHIND: "Standing",
        LegacyMovePool.GROUNDED: "Grounded",
        LegacyMovePool.RUNNING: "Running",
        LegacyMovePool.ROPE_REBOUND: "Rope_Rebound",
        LegacyMovePool.SPRINGBOARD: "Springboard",
        LegacyMovePool.DIVING_STANDING: "Diving",
        LegacyMovePool.DIVING_GROUNDED: "Diving",
        LegacyMovePool.WEAK_STRIKES: "Strikes/Weak",
        LegacyMovePool.MEDIUM_STRIKES: "Strikes/Medium",
        LegacyMovePool.STRONG_STRIKES: "Strikes/Stong",
        LegacyMovePool.SUBMISSION: "Submissions",
    }

    if not DirAccess.dir_exists_absolute("res://Moves"):
        DirAccess.make_dir_recursive_absolute("res://Moves")

    for data in move_list:
        var move_name: String = data[0]
        var legacy_pool: LegacyMovePool = data[1]
        var key_stat: MoveResource.KeyStat = data[2]
        var target_parts_raw: Array = data[3]
        var is_finisher: bool = data.size() > 4 and data[4]
        var explicit_is_submission: bool = data.size() > 5 and data[5]

        var new_move := MoveResource.new()
        new_move.move_name = move_name
        new_move.key_stat = [key_stat]
        new_move.is_finisher = is_finisher
        new_move.is_submission = explicit_is_submission

        var typed_parts: Array[MoveResource.CharacterBodyParts] = []
        for part in target_parts_raw:
            typed_parts.append(part)
        new_move.target_parts = typed_parts

        new_move.required_player_position = _map_required_player_position(legacy_pool)
        new_move.required_opponent_position = _map_required_opponent_position(move_name, legacy_pool, explicit_is_submission)

        var outcome := _resolve_outcome(move_name, legacy_pool, explicit_is_submission)
        new_move.outcome_opponent_position = outcome["opponent"]
        new_move.outcome_self_position = outcome["self"]
        new_move.is_submission = explicit_is_submission or outcome["is_submission"]

        var sub_folder: String = class_to_folder[legacy_pool]
        var folder_path := "res://Moves/" + sub_folder
        if is_finisher:
            folder_path += "/Finisher"
        if not DirAccess.dir_exists_absolute(folder_path):
            DirAccess.make_dir_recursive_absolute(folder_path)

        var safe_name := _safe_file_name(move_name) + ".tres"
        var path := folder_path + "/" + safe_name
        var save_result = ResourceSaver.save(new_move, path)
        if save_result != OK:
            push_error("Failed to save %s (%s)" % [path, error_string(save_result)])
        else:
            print("Generated: ", path)

func _map_required_player_position(pool: LegacyMovePool) -> MoveResource.CharacterStartPos:
    match pool:
        LegacyMovePool.RUNNING, LegacyMovePool.ROPE_REBOUND:
            return MoveResource.CharacterStartPos.RUNNING
        LegacyMovePool.SPRINGBOARD:
            return MoveResource.CharacterStartPos.SPRINGBOARD
        LegacyMovePool.DIVING_STANDING, LegacyMovePool.DIVING_GROUNDED:
            return MoveResource.CharacterStartPos.TOP_ROPE
        _:
            return MoveResource.CharacterStartPos.STANDING

func _map_required_opponent_position(move_name: String, pool: LegacyMovePool, explicit_is_submission: bool = false) -> Array[MoveResource.TargetPos]:
    if pool == LegacyMovePool.GROUNDED:
        return [MoveResource.TargetPos.GROUNDED]

    if pool == LegacyMovePool.DIVING_GROUNDED:
        return [MoveResource.TargetPos.GROUNDED]

    if explicit_is_submission or pool == LegacyMovePool.SUBMISSION:
        if _is_standing_submission(move_name):
            return [MoveResource.TargetPos.STANDING]
        return [MoveResource.TargetPos.GROUNDED]

    var name := move_name.to_lower()
    if "corner" in name:
        return [MoveResource.TargetPos.IN_CORNER]

    return [MoveResource.TargetPos.STANDING]

func _resolve_outcome(move_name: String, pool: LegacyMovePool, explicit_is_submission: bool = false) -> Dictionary:
    if explicit_is_submission or pool == LegacyMovePool.SUBMISSION:
        if _is_standing_submission(move_name):
            return {
                "opponent": MoveResource.MovePosition.STANDING,
                "self": MoveResource.MovePosition.STANDING,
                "is_submission": true,
            }
        return {
            "opponent": MoveResource.MovePosition.GROUNDED,
            "self": MoveResource.MovePosition.GROUNDED,
            "is_submission": true,
        }

    if pool == LegacyMovePool.SPRINGBOARD or pool == LegacyMovePool.DIVING_STANDING or pool == LegacyMovePool.DIVING_GROUNDED:
        return {
            "opponent": MoveResource.MovePosition.GROUNDED,
            "self": MoveResource.MovePosition.GROUNDED,
            "is_submission": false,
        }

    if pool == LegacyMovePool.RUNNING or pool == LegacyMovePool.ROPE_REBOUND:
        return {
            "opponent": MoveResource.MovePosition.GROUNDED,
            "self": MoveResource.MovePosition.STANDING,
            "is_submission": false,
        }

    var name := move_name.to_lower()

    if pool == LegacyMovePool.GROUNDED:
        if _contains_any(name, GROUNDED_BODY_DROP_KEYWORDS):
            return {
                "opponent": MoveResource.MovePosition.GROUNDED,
                "self": MoveResource.MovePosition.GROUNDED,
                "is_submission": false,
            }
        return {
            "opponent": MoveResource.MovePosition.GROUNDED,
            "self": MoveResource.MovePosition.STANDING,
            "is_submission": false,
        }

    if pool == LegacyMovePool.WEAK_STRIKES:
        return {
            "opponent": MoveResource.MovePosition.STANDING,
            "self": MoveResource.MovePosition.STANDING,
            "is_submission": false,
        }

    if pool == LegacyMovePool.MEDIUM_STRIKES or pool == LegacyMovePool.STRONG_STRIKES:
        if _contains_any(name, BIG_STRIKE_KEYWORDS):
            return {
                "opponent": MoveResource.MovePosition.GROUNDED,
                "self": MoveResource.MovePosition.STANDING,
                "is_submission": false,
            }
        return {
            "opponent": MoveResource.MovePosition.STANDING,
            "self": MoveResource.MovePosition.STANDING,
            "is_submission": false,
        }

    if _contains_any(name, DDT_DRIVER_KEYWORDS):
        return {
            "opponent": MoveResource.MovePosition.GROUNDED,
            "self": MoveResource.MovePosition.STANDING,
            "is_submission": false,
        }

    if _contains_any(name, SLAM_THROW_KEYWORDS):
        return {
            "opponent": MoveResource.MovePosition.GROUNDED,
            "self": MoveResource.MovePosition.STANDING,
            "is_submission": false,
        }

    return {
        "opponent": MoveResource.MovePosition.STANDING,
        "self": MoveResource.MovePosition.STANDING,
        "is_submission": false,
    }

func _is_standing_submission(move_name: String) -> bool:
    return _contains_any(move_name.to_lower(), STANDING_SUBMISSION_KEYWORDS)

func _contains_any(haystack: String, needles: Array) -> bool:
    for needle in needles:
        if needle in haystack:
            return true
    return false

func _safe_file_name(move_name: String) -> String:
    var sanitized := move_name.to_lower()
    sanitized = sanitized.replace(" ", "_")
    sanitized = sanitized.replace("-", "_")
    sanitized = sanitized.replace("'", "")
    sanitized = sanitized.replace("!", "")
    sanitized = sanitized.replace("(", "")
    sanitized = sanitized.replace(")", "")
    sanitized = sanitized.replace(".", "")
    sanitized = sanitized.replace("/", "_")
    return sanitized
