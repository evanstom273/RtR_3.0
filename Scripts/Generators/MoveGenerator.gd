    # Helper to convert Enum to a folder name
    var class_to_folder = {
        MoveResource.MovePosition.STANDING_IN_FRONT: "Standing_Front",
        MoveResource.MovePosition.STANDING_BEHIND: "Standing_Behind",
        MoveResource.MovePosition.RUNNING: "Running",
        MoveResource.MovePosition.ROPE_REBOUND: "Rope_Rebound",
        MoveResource.MovePosition.GROUNDED: "Grounded",
        MoveResource.MovePosition.SPRINGBOARD: "Springboard",
        MoveResource.MovePosition.DIVING_STANDING: "Diving_Standing",
        MoveResource.MovePosition.DIVING_GROUNDED: "Diving_Grounded",
        MoveResource.MovePosition.WEAK_STRIKES: "Strikes",
        MoveResource.MovePosition.MEDIUM_STRIKES: "Medium Strikes",
        MoveResource.MovePosition.STRONG_STRIKES: "Strong_Strikes",
        MoveResource.MovePosition.SUBMISSION: "Submissions"
    }

    # Ensure base directory exists
    if not DirAccess.dir_exists_absolute("res://Moves"):
        DirAccess.make_dir_absolute("res://Moves")

    for data in move_list:
        var new_move = MoveResource.new()
        new_move.MoveName = data[0]
        new_move.Move_Position = data[1]
        new_move.Key_Stat = data[2]
        new_move.Is_Finisher = data[4]
        
        # Convert standard Array to Typed Array[CharacterBodyParts]
        var typed_parts: Array[MoveResource.CharacterBodyParts] = []
        for part in data[3]:
            typed_parts.append(part)
        new_move.Target_Part = typed_parts
        
        # Create the sub-folder if it doesn't exist
        var sub_folder = class_to_folder[new_move.Move_Position]
        var folder_path = "res://Moves/" + sub_folder
        if not DirAccess.dir_exists_absolute(folder_path):
            DirAccess.make_dir_recursive_absolute(folder_path)
        
        # Save File in the sub-folder
        var safe_name = data[0].replace(" ", "_").to_lower() + ".tres"
        var path = folder_path + "/" + safe_name
        ResourceSaver.save(new_move, path)
        print("Generated: ", path)
